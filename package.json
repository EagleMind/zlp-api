{
  "name": "zpl-fluent-api",
  "version": "2.3.0",
  "description": "Design beautiful labels for Zebra printers without the headache of cryptic ZPL commands. Use real-world measurements (inches/mm) instead of counting dots.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build && npm test",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "analyze-docs": "ts-node scripts/analyze-docs.ts"
  },
  "keywords": [
    "zpl",
    "zebra",
    "label",
    "printing",
    "typescript",
    "fluent-api",
    "barcode",
    "industrial",
    "thermal",
    "zebra-printer"
  ],
  "author": {
    "name": "ZPL Fluent API Team",
    "email": "contact@example.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/EagleMind/zlp-api.git"
  },
  "bugs": {
    "url": "https://github.com/EagleMind/zlp-api/issues"
  },
  "homepage": "https://github.com/EagleMind/zlp-api#readme",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.15.0",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "eslint": "^8.37.0",
    "jest": "^29.5.0",
    "rimraf": "^4.4.1",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
